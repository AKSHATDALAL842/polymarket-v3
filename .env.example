# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# Polymarket CLOB API (optional — for live trading)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# Twitter API v2 (optional — real-time news stream)
TWITTER_BEARER_TOKEN=

# Telegram Bot (optional — channel monitoring)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_IDS=

# NewsAPI.org (optional)
NEWSAPI_KEY=

# OpenAI (optional — for OpenAI embedding backend)
# OPENAI_API_KEY=
# EMBEDDING_BACKEND=openai

# Pipeline Settings
DRY_RUN=true
MAX_BET_USD=25
DAILY_LOSS_LIMIT_USD=100
BANKROLL_USD=1000
EDGE_THRESHOLD=0.06

# Market Filters
MAX_VOLUME_USD=500000
MIN_VOLUME_USD=1000
MATERIALITY_THRESHOLD=0.55
SPEED_TARGET_SECONDS=5

# Risk Controls
MAX_CONCURRENT_POSITIONS=5
MAX_EXPOSURE_PER_CATEGORY_USD=60
CONSECUTIVE_LOSS_COOLDOWN=3
COOLDOWN_MINUTES=30
